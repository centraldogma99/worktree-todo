{
  "name": "@worktree-todo/app",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "pnpm build && electron dist/main/index.js",
    "build": "pnpm build:core && pnpm build:main && pnpm build:preload && pnpm build:renderer && pnpm build:assets",
    "build:core": "pnpm --filter @worktree-todo/core build",
    "build:main": "tsc -p tsconfig.main.json",
    "build:preload": "tsc -p tsconfig.preload.json",
    "build:renderer": "tsc -p tsconfig.renderer.json",
    "build:assets": "node scripts/copy-assets.mjs",
    "start": "electron dist/main/index.js",
    "package": "pnpm build && electron-builder --mac dir --config electron-builder.yml",
    "sign": "bash scripts/sign.sh"
  },
  "dependencies": {
    "@worktree-todo/core": "workspace:*",
    "electron-store": "^10.0.0"
  },
  "devDependencies": {
    "electron": "30.5.1",
    "electron-builder": "^24.0.0",
    "typescript": "^5.4.0",
    "@types/node": "^20.11.0"
  }
}
